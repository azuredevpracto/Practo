{
	"name": "01-Bronze_to_Silver",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "ParquetSource",
						"additionalColumns": [
							{
								"name": "File_Name",
								"value": "$$FILENAME"
							}
						],
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "ParquetReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"preCopyScript": {
							"value": "@{concat('TRUNCATE TABLE ', pipeline().parameters.Silver_Schema_Name,'.',pipeline().parameters.Silver_Table_Name)}",
							"type": "Expression"
						},
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "DS_ADLS_Parquet",
						"type": "DatasetReference",
						"parameters": {
							"File_Name": {
								"value": "@pipeline().parameters.Bronze_File_Name",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_SQL",
						"type": "DatasetReference",
						"parameters": {
							"Schema_Name": {
								"value": "@pipeline().parameters.Silver_Schema_Name",
								"type": "Expression"
							},
							"Table_Name": {
								"value": "@pipeline().parameters.Silver_Table_Name",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"Bronze_File_Path": {
				"type": "string"
			},
			"Bronze_File_Name": {
				"type": "string"
			},
			"Silver_Schema_Name": {
				"type": "string"
			},
			"Silver_Table_Name": {
				"type": "string"
			}
		},
		"folder": {
			"name": "AW-Practo_1"
		},
		"annotations": [],
		"lastPublishTime": "2026-05-10T12:23:52Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}